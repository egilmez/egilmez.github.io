{
  "manifest_version": 3,
  "name": "Record Studio",
  "version": "1.0.0",
  "description": "Browse Discogs record listings in a beautiful vinyl crate interface.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Record Studio",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "host_permissions": [
    "https://api.discogs.com/*",
    "https://www.discogs.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
